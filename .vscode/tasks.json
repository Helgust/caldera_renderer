{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run clang-tidy current file",
      "type": "shell",
      "command": "clang-tidy",
      "args": [
        {
          "value": "${file}",
          "quoting": "strong"
        },
        "--quiet",
        "-p",
        "build"
      ],
      "problemMatcher": "$gcc",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Git Push",
      "type": "shell",
      "command": "git push origin HEAD:$(git rev-parse --abbrev-ref HEAD)",
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated"
      }
    },
    {
      "label": "Clang format changed files",
      "type": "shell",
      "command": "git diff -U0 | python tools/clang-format-diff.py -i -v -p1 -iregex '.*\\.(cpp|cc|cxx|h|hpp|hxx|inl)$'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Clang format last commit",
      "type": "shell",
      "command": "git diff -U0 HEAD~1 | python tools/clang-format-diff.py -i -v -p1 -iregex '.*\\.(cpp|cc|cxx|h|hpp|hxx|inl)$'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Clang format current file",
      "type": "shell",
      "command": "clang-format",
      "args": [
        "-i",
        {
          "value": "${file}",
          "quoting": "strong"
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Open Vulkan Validation Log",
      "type": "shell",
      "command": "code '${workspaceFolder}/build/validation.log'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Install All Recommended Extensions",
      "type": "shell",
      "windows": {
        "command": "foreach ($ext in (Get-Content -Raw .vscode/extensions.json | ConvertFrom-Json).recommendations) { Write-Host Installing $ext; code --install-extension $ext; }",
        "options": {
          "shell": {
            "executable": "powershell.exe",
            "args": ["-NoProfile", "-Command"]
          }
        }
      },
      "linux": {
        "command": "cat .vscode/extensions.json | jq .recommendations[] | xargs -n 1 code . --install-extension"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": []
    },
    {
      "label": "Bundle Codebase for Claude",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/codebase_bundler.py"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Scan Scenes",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/scan_scenes.py"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Compile shaders",
      "type": "process",
      "command": "cmd.exe",
      "args": ["/c", "tools\\compile_shaders.bat"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "slang",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^(error|warning)\\[?\\w*\\]?:\\s+(.*)$",
            "severity": 1,
            "message": 2
          },
          {
            "regexp": "^\\s*-->\\s+(.+):(\\d+):(\\d+)\\s*$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
